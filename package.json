{
  "name": "bytemsg233",
  "displayName": "ByteMsg233 Language Support",
  "description": "VS Code language support for legacy ByteMsg233 (.bmsg) schema files; new projects use .bmsg.json.",
  "version": "1.0.0",
  "publisher": "neko233",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neko233-com/bytemsg233-plugin-vscode"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "bytemsg233",
    "bmsg",
    "schema",
    "serialization"
  ],
  "contributes": {
    "languages": [
      {
        "id": "bmsg",
        "aliases": [
          "ByteMsg233",
          "bmsg"
        ],
        "extensions": [
          ".bmsg"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bmsg",
        "scopeName": "source.bmsg",
        "path": "./syntaxes/bmsg.tmLanguage.json"
      }
    ]
  }
}
